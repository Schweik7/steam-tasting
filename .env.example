# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Steam Web API key (the ONE key the developer registers; users never need one).
# Get it at https://steamcommunity.com/dev/apikey  (domain can be localhost).
STEAM_API_KEY=

# Long random string used to sign session cookies. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Port the backend listens on.
PORT=8787

# Externally reachable base URL of THIS backend. Used to build the OpenID
# realm + return_to, so it MUST match what the browser actually hits.
#   - Local dev (with the Vite proxy):  http://localhost:5173
#   - Production self-host:             https://your-domain.example
PUBLIC_URL=http://localhost:5173

# Where to send the user after a successful login (usually the site root).
FRONTEND_URL=/

# Optional outbound proxy for reaching Steam, e.g. http://127.0.0.1:7890.
# Only needed where api.steampowered.com / steamcommunity.com are blocked
# (e.g. a local Clash/V2Ray). Leave empty on normal servers.
PROXY_URL=

# Invite code(s) that unlock the developer LLM (MagicVal). Comma-separated;
# the value never reaches the browser.
INVITE_CODES=xxxxx,yyyyyy,some-long-random-string

# Developer-provided LLM, used when a user enters a valid invite code
# (so they don't need their own API). Leave empty to disable that path.
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
# Higher-tier model used for the two poems on the MagicVal path.
LLM_MODEL_PRO=deepseek-v4-pro

# Optional: where to store the SQLite DB (saved reports + poems). Any
# SQLAlchemy URL; defaults to data/steam-tasting.db under the repo.
# DATABASE_URL=sqlite:////opt/steam-tasting/data/steam-tasting.db

# Optional admin console. Set a secret URL segment to enable an
# unauthenticated admin view at /<ADMIN_PATH> (API under /api/<ADMIN_PATH>/*)
# that lists users and shows each one's games + report + poems. Security is
# only the secrecy of this path, so make it unguessable. Empty = disabled.
ADMIN_PATH=just-for-fun
